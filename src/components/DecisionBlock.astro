---
interface Props {
  label: string;
  artifact?: string;
  artifactAlt?: string;
}

const { label, artifact, artifactAlt } = Astro.props;
---
<div class="decision-block" data-rules>
  <div class="decision-content">
    <p class="decision-label">Decision: {label}</p>
    <div class="decision-text">
      <slot />
    </div>
  </div>
  {artifact && (
    <div class="decision-artifact">
      <img src={artifact} alt={artifactAlt ?? ''} loading="lazy" />
    </div>
  )}
  {Astro.slots.has('artifact') && (
    <div class="decision-artifact">
      <slot name="artifact" />
    </div>
  )}
</div>

<style>
  .decision-block {
    background: rgba(245, 230, 200, 0.03);
    border-left: 2px solid rgba(245, 230, 200, 0.25);
    padding: 20px 24px;
    border-radius: 2px;
    margin: 24px 0;
    display: grid;
    grid-template-columns: 1fr 200px;
    gap: 24px;
    align-items: start;
  }

  .decision-content {
    min-width: 0;
  }

  .decision-label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--color-cream-dim);
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .decision-text {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-cream);
  }

  .decision-artifact {
    width: 200px;
    border: 1px solid var(--color-cream-faint);
    border-radius: 2px;
    overflow: hidden;
    background: rgba(245, 230, 200, 0.04);
  }

  .decision-artifact img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 1023px) {
    .decision-block {
      grid-template-columns: 1fr;
    }

    .decision-artifact {
      width: 100%;
    }
  }
</style>
