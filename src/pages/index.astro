---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeftPanel from '../components/LeftPanel.astro';
import MobileHeader from '../components/MobileHeader.astro';
import FooterEcho from '../components/FooterEcho.astro';
---
<BaseLayout title="Maria Angelika Agutaya — Design Engineer">
  <MobileHeader />
  <LeftPanel activeSection="work" />
  <main style="margin-left: var(--panel-width); padding: 48px 64px; max-width: 100vw;">
    <p class="font-mono" style="font-size: 12px; color: var(--color-cream-dim); letter-spacing: 0.08em; text-transform: uppercase;">
      Phase 2 scaffold. Landing sections land in Task 11.
    </p>
    <FooterEcho />
  </main>
</BaseLayout>
